# ════════════════════════════════════════════════════════════
#  Frame/0 Studio — 环境变量
#  复制为 .env.local 再填写。.env.local 已被 .gitignore，不会进 git。
# ════════════════════════════════════════════════════════════

# ─── 必需 · 视频 / 图片生成 ───
# 阿里云百炼 DashScope API Key，驱动 Wan / Kling / PixVerse / HappyHorse 全部模型。
# 获取：https://bailian.console.aliyun.com/
#
# 可留空：用户能在网页「设置 ⚙」里自行填写 key（存浏览器 localStorage，优先于此处）。
# 公开分享 / 部署时建议留空 —— 强制每位访客自带 key，避免访客共用你的额度。
DASHSCOPE_API_KEY=

# ─── 可选 · 「灵感」页 Reddit 数据源 ───
# 仅 /api/discover 抓取 Reddit 热帖时使用。
# 获取：https://www.reddit.com/prefs/apps （创建 "script" 类型应用）
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=

# ─── 可选 · 阿里云 OSS 持久存储（默认关）───
# 把 data/uploads/ 和 data/videos/ 持久化到 OSS（作为现有 thumbDataUrl/IDB/
# 本地镜像三层渲染冗余之外的第四层兜底，也是 K8s 多副本部署的共享后端）。
#
# 默认关闭 → 一切走本地 data/，不产生 OSS 费用（当前行为）。
# 启用流程：
#   1. 阿里云开 OSS bucket + 创建 AK/SK（详见 deploy/README.md 第九节）
#   2. OSS_ENABLED=true
#   3. 填下面 BUCKET / AK / SK
#   4. 重启服务，看 server log 有 `[oss] initialized` 一行即生效
#
# 总开关 —— 必须显式 "true" 才启用，避免凭证误填就自动产生流量/存储费
OSS_ENABLED=false
OSS_REGION=oss-cn-hangzhou
OSS_BUCKET=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
# 可选 key 前缀，用于同一 bucket 隔离 prod / staging / dev，如 "prod/"
OSS_KEY_PREFIX=
